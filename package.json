{
  "name": "@hyperttp/queue",
  "version": "1.1.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./dist/package.json"
  },
  "keywords": [
    "hyperttp"
  ],
  "author": "dirold2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IT-IF-OR/hyperttp-queue.git"
  },
  "peerDependencies": {
    "@hyperttp/types": "^0.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "globals": "^17.6.0",
    "@dirold2/dev-tools": "^1.0.16",
    "typescript-eslint": "^8.60.0",
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^6.0.3",
    "vitest": "latest",
    "prettier": "latest",
    "eslint": "latest",
    "jiti": "^2.7.0"
  },
  "scripts": {
    "build": "tsc && d-build",
    "dist": "d-dist",
    "deploy": "npm run build && npm run dist",
    "publish": "d-publish",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,js}'",
    "format": "prettier --write .",
    "test": "vitest run",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  }
}
